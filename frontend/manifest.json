{
  "name": "Laboria - Fase 6 Next-Gen",
  "short_name": "Laboria",
  "description": "Plataforma integral de empleo y formación profesional - Fase 6 Next-Gen con IA, Blockchain y Real-time",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#667eea",
  "theme_color": "#667eea",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "es",
  "dir": "ltr",
  "categories": ["business", "education", "productivity"],
  "shortcuts": [
    {
      "name": "Buscar Empleos",
      "short_name": "Empleos",
      "description": "Buscar oportunidades laborales",
      "url": "/jobs",
      "icons": [
        {
          "src": "/assets/logo-blanco-vertical.png",
          "sizes": "any"
        }
      ]
    },
    {
      "name": "Mis Cursos",
      "short_name": "Cursos",
      "description": "Ver mis cursos inscritos",
      "url": "/courses/my-courses",
      "icons": [
        {
          "src": "/assets/logo-blanco-vertical.png",
          "sizes": "any"
        }
      ]
    }
  ],
  "icons": [
    {
      "src": "/assets/logo-blanco-vertical.png",
      "sizes": "any",
      "type": "image/png"
    }
  ],
  "splash_pages": null,
  "screenshots": [
    {
      "src": "screenshots/desktop-1.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Dashboard principal de Laboria"
    },
    {
      "src": "screenshots/mobile-1.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Búsqueda de empleos en móvil"
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": ["navigate-existing", "focus-existing"]
  },
  "protocol_handlers": [
    {
      "protocol": "web+laboria",
      "url": "/handler?protocol=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/upload-cv",
      "accept": {
        "application/pdf": [".pdf"],
        "application/msword": [".doc", ".docx"],
        "text/plain": [".txt"]
      }
    }
  ],
  "share_target": {
    "action": "/share-profile",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "profile_title",
      "text": "profile_description",
      "url": "profile_url",
      "files": [
        {
          "name": "cv_file",
          "accept": ["application/pdf", ".pdf"]
        }
      ]
    }
  },
  "share_handler": {
    "action": "/share-job",
    "method": "GET",
    "params": {
      "title": "job_title",
      "text": "job_description",
      "url": "job_url"
    }
  }
}
